FROM quay.io/centos/centos:stream9 AS builder

WORKDIR /build

RUN dnf install -y \
    python3.12 \
    python3.12-pip \
    python3.12-devel \
    gcc && \
    dnf clean all

COPY pyproject.toml ./
COPY src/ src/
RUN pip3.12 install --no-cache-dir --prefix=/install .

FROM quay.io/centos/centos:stream9

RUN dnf install -y \
    python3.12 \
    https://dl.fedoraproject.org/pub/epel/epel-release-latest-9.noarch.rpm \
    https://github.com/ros-infrastructure/ros-apt-source/releases/download/1.2.0/ros2-release-1.2.0-1.noarch.rpm && \
    dnf config-manager --set-enabled crb && \
    dnf install -y \
    ros-jazzy-rclpy \
    ros-jazzy-sensor-msgs \
    ros-jazzy-simulation-interfaces && \
    dnf clean all

COPY --from=builder /install /usr/local
COPY src/ /app/src/

WORKDIR /app
EXPOSE 8000 9876 9090

ENV PLAYGROUND_CONFIG=/etc/robotics-playground/config.yaml

USER 1001

CMD ["python3.12", "-m", "uvicorn", "robotics_playground.main:app", "--host", "0.0.0.0", "--port", "8000"]
