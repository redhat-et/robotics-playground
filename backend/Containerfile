FROM docker.io/ros:jazzy AS builder

WORKDIR /build

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3-dev gcc && \
    rm -rf /var/lib/apt/lists/*

COPY pyproject.toml ./
COPY src/ src/
RUN python3 -m venv /venv && \
    /venv/bin/pip install --no-cache-dir . && \
    cp -a /venv/lib/python3.12/site-packages /install-pkgs

FROM docker.io/ros:jazzy

COPY --from=builder /install-pkgs /usr/lib/python3/dist-packages
COPY src/ /app/src/

RUN mkdir -p /app/.home && chmod g+w /app/.home

WORKDIR /app
EXPOSE 8000 9876

ENV PLAYGROUND_CONFIG=/etc/robotics-playground/config.yaml
ENV HOME=/app/.home

USER 1001

CMD ["python3", "-m", "uvicorn", "robotics_playground.main:app", "--host", "0.0.0.0", "--port", "8000", "--loop", "asyncio"]
