FROM docker.io/ros:jazzy AS builder

WORKDIR /build

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3-pip python3-dev gcc && \
    rm -rf /var/lib/apt/lists/*

COPY pyproject.toml ./
COPY src/ src/
RUN pip3 install --no-cache-dir --break-system-packages --prefix=/install .

FROM docker.io/ros:jazzy

COPY --from=builder /install /usr/local
COPY src/ /app/src/

WORKDIR /app
EXPOSE 8000 9876 9090

ENV PLAYGROUND_CONFIG=/etc/robotics-playground/config.yaml

USER 1001

CMD ["python3", "-m", "uvicorn", "robotics_playground.main:app", "--host", "0.0.0.0", "--port", "8000"]
