FROM registry.access.redhat.com/ubi10/ubi AS builder

WORKDIR /build

RUN dnf install -y python3-pip python3-devel gcc && dnf clean all

COPY pyproject.toml ./
COPY src/ src/
RUN pip3 install --no-cache-dir --prefix=/install .

FROM registry.access.redhat.com/ubi10/ubi

COPY hellaenergy-ros2.repo /etc/yum.repos.d/hellaenergy-ros2.repo

RUN rpm --import https://download.copr.fedorainfracloud.org/results/hellaenergy/ros2/pubkey.gpg && \
    dnf install -y python3 ros-jazzy-rclpy ros-jazzy-sensor-msgs && \
    dnf clean all

COPY --from=builder /install /usr/local
COPY src/ /app/src/

WORKDIR /app
EXPOSE 8000 9876 9090

ENV PLAYGROUND_CONFIG=/etc/robotics-playground/config.yaml

USER 1001

CMD ["python3", "-m", "uvicorn", "robotics_playground.main:app", "--host", "0.0.0.0", "--port", "8000"]
