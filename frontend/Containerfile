FROM docker.io/library/node:22-slim AS builder

WORKDIR /build
COPY package.json package-lock.json* ./
RUN npm ci
COPY tsconfig.json webpack.config.js ./
COPY public/ public/
COPY src/ src/
RUN npm run build && \
    gzip -k -9 dist/rerun/re_viewer_bg.wasm

FROM registry.access.redhat.com/hi/nginx:latest

COPY --from=builder --chown=65532:0 /build/dist/ /opt/app-root/src/
COPY --chown=65532:0 nginx.conf /etc/nginx/nginx.conf

EXPOSE 8080
